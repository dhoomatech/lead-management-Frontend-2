// prisma/schema.prisma
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  QUALIFIED
  DISQUALIFIED
  PENDING
}

enum LeadSource {
  Facebook
  Instagram
  Google
  LinkedIn
}

enum UserRole {
  Admin
  Manager
  Salesperson
  DigitalMarketer
}

model Lead {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String
  email     String
  source    LeadSource
  status    LeadStatus @default(NEW)
  assignTo  String     @default("Unassigned")
  dateAdded DateTime   @default(now())
  feedback  Feedback[]
  timeline  TimelineEvent[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  name      String
  role      UserRole
  email     String   @unique
  initials  String
  createdAt DateTime @default(now())
}

model Feedback {
  id         Int      @id @default(autoincrement())
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId     Int
  message    String
  createdBy  String
  createdAt  DateTime @default(now())
}

model TimelineEvent {
  id           Int      @id @default(autoincrement())
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId       Int
  title        String
  description  String
  performedBy  String
  performedAt  DateTime @default(now())
}
